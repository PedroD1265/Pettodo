# PETTODO App Configuration
# Copy this file to .env and fill in values to activate integrations.
# NEVER commit .env with real secrets to the repository.

# App mode: "demo" runs fully offline with local data simulation.
# Set to "integration" to use real external providers below.
VITE_APP_MODE=demo

# Auth provider: "demo" uses synthetic user, "firebase" uses real Google Sign-In
VITE_AUTH_PROVIDER=demo

# Firebase Auth (required when VITE_APP_MODE=integration)
# VITE_FIREBASE_API_KEY=your_firebase_api_key
# VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
# VITE_FIREBASE_PROJECT_ID=your-project-id
# VITE_FIREBASE_APP_ID=your_firebase_app_id
# VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id

# Firebase Admin SDK (backend only — NEVER expose in client)
# FIREBASE_PROJECT_ID=your-project-id
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxx@your-project.iam.gserviceaccount.com
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Storage provider for photo/document uploads
# demo: stores as data URLs in localStorage (<=500KB cap)
# azure: Azure Blob Storage (requires backend SAS token endpoint)
# gcs: Google Cloud Storage (requires backend signed URL endpoint)
VITE_STORAGE_PROVIDER=demo
# (Integration) Azure Blob — set on backend, not client
# AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...
# AZURE_CONTAINER_NAME=pettodo-uploads

# SMS / OTP verification
# demo: OTP is always "123456"
# twilio: Twilio Verify (requires backend proxy — never put secrets in client)
VITE_SMS_PROVIDER=demo
# (Integration) Twilio — set on backend only
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=your_auth_token_here
# TWILIO_FROM_NUMBER=+1234567890

# Realtime chat transport
# demo: messages stored in localStorage via EntityStore
# ably | pusher | supabase: requires VITE_CHAT_* keys (see docs/INTEGRATIONS.md)
VITE_CHAT_PROVIDER=demo
# VITE_ABLY_API_KEY=your_ably_api_key_here
# VITE_PUSHER_APP_KEY=your_pusher_app_key_here
# VITE_PUSHER_CLUSTER=mt1

# Push notifications
# demo: in-app notification list + sonner toasts
# fcm: Firebase Cloud Messaging (requires service worker setup)
VITE_PUSH_PROVIDER=demo
# VITE_FIREBASE_CONFIG_JSON={"projectId":"...","messagingSenderId":"...","appId":"..."}

# Maps / Geocoding
# osm: OpenStreetMap via Leaflet (default, no key required)
# google: Google Maps JS + Places (requires API key)
VITE_MAP_PROVIDER=osm
# VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# AI assistant and matching
# demo: keyword search over Education articles, no LLM
# gemini: Gemini Flash/Pro via backend proxy (never put API key in client)
VITE_AI_PROVIDER=demo
# (Integration) Gemini — set on backend only
# GEMINI_API_KEY=your_gemini_api_key_here

# Backend API base URL (leave empty for local-first demo)
VITE_API_BASE_URL=
